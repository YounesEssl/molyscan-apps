# Database
DATABASE_URL="postgresql://molyscan:molyscan_dev@localhost:5432/molyscan?schema=public"

# JWT
JWT_SECRET="change-me-in-production"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# MinIO
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="molyscan"
MINIO_SECRET_KEY="molyscan_dev"
MINIO_BUCKET="molyscan"
MINIO_USE_SSL=false

# Ollama (RAG / LLM)

# Sellbase PIM (server-side only — never expose these as EXPO_PUBLIC_* variables)
SELLBASE_API_URL=https://sellapi-preprod.sellbase-plateforme.com
SELLBASE_SERVER=base05
SELLBASE_BASE=c_molydal
SELLBASE_PUBLICATION_ID=52903
SELLBASE_EMAIL=
SELLBASE_PASSWORD=
# Base URL from which authenticated PIM files are served. Confirm with Sellbase.
SELLBASE_MEDIA_BASE_URL=
MOLYDAL_PUBLIC_URL=https://www.molydal.com
SELLBASE_TOKEN_CACHE_PATH=/tmp/molyscan-sellbase-token.json

# Must be identical for document indexing and query embeddings.
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_DIMENSIONS=1536
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="mistral"
OLLAMA_EMBEDDING_MODEL="nomic-embed-text"

# Whisper (Transcription)
WHISPER_MODEL_PATH="./models/whisper-small"

# Expo Push
EXPO_PUSH_ACCESS_TOKEN=""

# Resend (emails transactionnels)
RESEND_API_KEY=""
# Adresse expéditeur (doit appartenir à un domaine vérifié dans Resend)
RESEND_FROM_EMAIL="Molyscan <no-reply@votre-domaine.fr>"

# CRM Innovation (icyapi) — sync des notes vocales en communications
CRM_BASE_URL="https://molydal.innovationcrm.fr/backend/icyapi"
# Clé de chiffrement (AES-256-GCM) des identifiants CRM stockés par commercial
CRM_ENCRYPTION_KEY="change-me-in-production"

# Console d'administration web (plateforme Vite/React)
# URL utilisée dans l'email admin pour pointer vers la page de validation
ADMIN_WEB_URL="http://localhost:5173"

# App
PORT=3000
NODE_ENV=development
API_PREFIX=api
