generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ─── ENUMS ────────────────────────────────────────

enum UserRole {
  commercial
  distributor
  admin
}

enum UserStatus {
  pending
  approved
  rejected
}

enum ScanStatus {
  matched
  partial
  no_match
}

enum ScanMethod {
  barcode
  label
  voice
  image
}

enum WorkflowStatus {
  draft
  submitted
  under_review
  approved
  rejected
}

enum NotificationType {
  scan_match
  price_approved
  price_rejected
  ai_response
  workflow_update
  system
}

enum ExportFormat {
  pdf
  csv
  xlsx
}

enum ExportStatus {
  generating
  ready
  failed
}

enum PricingTier {
  standard
  premium
  enterprise
}

enum RagSyncStatus {
  queued
  running
  validating
  completed
  failed
  skipped
}

enum RagSyncTrigger {
  manual
  scheduled
}

enum RagIndexStatus {
  building
  validating
  active
  archived
  failed
}

// ─── MODELS ───────────────────────────────────────

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  passwordHash   String
  firstName      String
  lastName       String
  role           UserRole
  status         UserStatus @default(pending)
  company        String?
  phone          String?
  avatarUrl      String?
  organizationId String?
  pushToken      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  scans                   Scan[]
  workflows               PriceWorkflow[]
  receivedWorkflows       PriceWorkflow[]          @relation("WorkflowRecipients")
  conversations           AIConversation[]
  notifications           Notification[]
  voiceNotes              VoiceNote[]
  exports                 ExportRecord[]
  refreshTokens           RefreshToken[]
  passwordResetTokens     PasswordResetToken[]
  conversationSubmissions ConversationSubmission[]
  equivalentFeedbacks     ScanEquivalentFeedback[]
  departments             Department[]             @relation("UserDepartments")
  crmCredential           CrmCredential?

  @@map("users")
}

model Department {
  id        String   @id @default(uuid())
  code      String?  @unique
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]          @relation("UserDepartments")
  routedWorkflows PriceWorkflow[] @relation("WorkflowDepartment")

  @@map("departments")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  // Hash bcrypt du code à 6 chiffres (jamais stocké en clair).
  codeHash  String
  expiresAt DateTime
  attempts  Int       @default(0)
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model CompetitorProduct {
  id          String   @id @default(uuid())
  barcode     String   @unique
  name        String
  brand       String
  category    String
  subcategory String?
  description String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  equivalences ProductEquivalence[]
  scans        Scan[]

  @@map("competitor_products")
}

model MolydalProduct {
  id                String      @id @default(uuid())
  reference         String      @unique
  name              String
  category          String
  description       String?
  pricingTier       PricingTier @default(standard)
  technicalSheetUrl String?
  advantages        String[]
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  equivalences ProductEquivalence[]
  workflows    PriceWorkflow[]

  @@map("molydal_products")
}

model ProductEquivalence {
  id                  String @id @default(uuid())
  competitorProductId String
  molydalProductId    String
  confidenceScore     Int

  competitorProduct CompetitorProduct @relation(fields: [competitorProductId], references: [id])
  molydalProduct    MolydalProduct    @relation(fields: [molydalProductId], references: [id])

  createdAt DateTime @default(now())

  @@unique([competitorProductId, molydalProductId])
  @@map("product_equivalences")
}

enum EquivalenceSource {
  expert
  feedback
}

/// Expert-validated mapping from a scanned competitor product to its Molydal
/// equivalent. Keyed on the NORMALIZED "brand|name" so a scan can look it up
/// deterministically (Vision reliably reads brand+name). When present it
/// short-circuits the RAG pipeline with the expert's authoritative answer.
/// Curated in the admin platform; seeded/grown from scan feedback.
model ExpertEquivalence {
  id                String            @id @default(uuid())
  competitorBrand   String
  competitorName    String
  /// normalize(brand) + '|' + normalize(name) — unique lookup key
  competitorKey     String            @unique
  /// Molydal product name (free text, as it appears in the catalog / scan result)
  molydalEquivalent String
  molydalFamily     String?
  confidence        Int               @default(100)
  note              String?
  /// Admin who validated this entry (email), for traceability
  validatedBy       String?
  source            EquivalenceSource @default(expert)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([competitorBrand])
  @@map("expert_equivalences")
}

model Scan {
  id                  String     @id @default(uuid())
  barcode             String?
  status              ScanStatus
  scanMethod          ScanMethod @default(barcode)
  // Idempotency key from the mobile offline outbox — dedupes replayed syncs.
  clientRequestId     String?    @unique
  locationLat         Float?
  locationLng         Float?
  locationLabel       String?
  userId              String
  competitorProductId String?
  organizationId      String?

  // Image analysis results (stored directly, no CompetitorProduct needed)
  identifiedName      String?
  identifiedBrand     String?
  identifiedType      String?
  identifiedSpecs     String?
  molydalEquivalent   String?
  equivalentFamily    String?
  compatibility       Int?
  analysisText        String?
  equivalentsJson     Json?
  photoKey            String?

  user              User               @relation(fields: [userId], references: [id])
  competitorProduct CompetitorProduct?  @relation(fields: [competitorProductId], references: [id])

  workflows           PriceWorkflow[]
  conversations       AIConversation[]
  voiceNotes          VoiceNote[]
  equivalentFeedbacks ScanEquivalentFeedback[]

  scannedAt DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([identifiedName, identifiedBrand])
  @@map("scans")
}

enum EquivalentFeedbackVote {
  up
  down
}

model ScanEquivalentFeedback {
  id              String                 @id @default(uuid())
  scanId          String
  userId          String
  equivalentName  String
  vote            EquivalentFeedbackVote
  suggestedName   String?

  scan Scan @relation(fields: [scanId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([scanId])
  @@index([createdAt])
  @@map("scan_equivalent_feedbacks")
}

model PriceWorkflow {
  id               String         @id @default(uuid())
  // Idempotency key from the mobile offline outbox — dedupes replayed syncs.
  clientRequestId  String?        @unique
  scanId           String
  // Optional FK — AI-identified equivalents are free-text, not catalog rows.
  molydalProductId String?
  // Product identity stored directly (AI equivalent name/ref or catalog fallback).
  productName      String?
  molydalRef       String?
  // Optionnels : une demande de prix distributeur se fait sans formulaire
  // (un simple envoi). Conservés pour le legacy / l'éventuelle saisie manuelle.
  clientName       String?
  quantity         Float?
  unit             String         @default("L")
  requestedPrice   Float?
  approvedPrice    Float?
  status           WorkflowStatus @default(draft)
  userId           String
  reviewedById     String?
  reviewComment    String?
  organizationId   String?

  // Routage : la demande d'un distributeur est envoyée aux commerciaux de son
  // département (recipients). Si aucun commercial, repli sur les admins
  // (routedToAdmins = true). Conservé pour traçabilité côté plateforme admin.
  routedDepartmentId String?
  routedToAdmins     Boolean @default(false)

  scan             Scan            @relation(fields: [scanId], references: [id])
  molydalProduct   MolydalProduct? @relation(fields: [molydalProductId], references: [id])
  user             User            @relation(fields: [userId], references: [id])
  routedDepartment Department?     @relation("WorkflowDepartment", fields: [routedDepartmentId], references: [id])
  recipients       User[]          @relation("WorkflowRecipients")

  steps WorkflowStep[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("price_workflows")
}

model WorkflowStep {
  id         String         @id @default(uuid())
  workflowId String
  status     WorkflowStatus
  actor      String
  comment    String?
  date       DateTime       @default(now())

  workflow PriceWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@map("workflow_steps")
}

model AIConversation {
  id               String  @id @default(uuid())
  type             String  @default("product") // "free" | "product"
  title            String  @default("Nouvelle conversation")
  scanId           String?
  scannedName      String?
  scannedBrand     String?
  molydalName      String?
  molydalReference String?
  userId           String

  scan        Scan?                    @relation(fields: [scanId], references: [id])
  user        User                     @relation(fields: [userId], references: [id])
  messages    AIMessage[]
  submissions ConversationSubmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ai_conversations")
}

model ConversationSubmission {
  id             String @id @default(uuid())
  conversationId String
  userId         String

  conversation AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User           @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([conversationId])
  @@map("conversation_submissions")
}

model AIMessage {
  id             String   @id @default(uuid())
  conversationId String
  role           String
  text           String
  sources        String[]

  conversation AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  timestamp DateTime @default(now())

  @@map("ai_messages")
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  relatedId String?
  userId    String

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@map("notifications")
}

model ExportRecord {
  id          String       @id @default(uuid())
  fileName    String
  format      ExportFormat
  status      ExportStatus @default(generating)
  size        String?
  fileKey     String?
  filters     Json?
  userId      String

  user User @relation(fields: [userId], references: [id])

  generatedAt DateTime @default(now())

  @@map("export_records")
}

model VoiceNote {
  id               String   @id @default(uuid())
  duration         Int
  audioKey         String?
  transcription    String?
  clientName       String?
  // GUID de la société dans le CRM Innovation (renseigné via le sélecteur société).
  companyId        String?
  // GUID de la personne/contact dans le CRM Innovation.
  contactId        String?
  contactName      String?
  // Date/heure du rendez-vous à utiliser comme date de communication CRM.
  meetingAt        DateTime?
  productMentioned String?
  nextAction       String?
  notes            String?
  // pending | synced | failed — état de la pousse vers le CRM (communication).
  syncStatus       String   @default("pending")
  // ID de la communication créée côté CRM (comm_communicationid).
  crmCommunicationId String?
  relatedScanId    String?
  userId           String

  scan Scan? @relation(fields: [relatedScanId], references: [id])
  user User  @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@map("voice_notes")
}

/// Identifiants Innovation CRM (icyapi) propres à chaque commercial.
/// Le mot de passe est chiffré au repos (AES-256-GCM, clé CRM_ENCRYPTION_KEY).
/// idToken/tokenExpiresAt mettent en cache le Bearer renvoyé par /Connection/Login.
model CrmCredential {
  id             String    @id @default(uuid())
  userId         String    @unique
  login          String
  passwordEnc    String
  // Id de l'utilisateur côté CRM (renvoyé au login) → propriétaire des communications.
  crmUserId      String?
  idToken        String?
  tokenExpiresAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("crm_credentials")
}

model DocumentEmbedding {
  id        String                       @id @default(uuid())
  content   String
  source    String
  metadata  Json?
  embedding Unsupported("vector(1536)")
  createdAt DateTime                     @default(now())

  @@map("document_embeddings")
}

/// Canonical, reproducible copy of a Sellbase level-4 product.
model PimProduct {
  id                String   @id @default(uuid())
  sellbaseElementId Int      @unique
  sellbaseInstanceId Int?
  name              String
  family            String?
  subfamily         String?
  shortDescription  String?
  description       String?
  usage             String?
  baseOil           String?
  thickener         String?
  nlgiGrade         String?
  viscosity40       Float?
  baseOilViscosity40 Float?
  temperatureMin    Float?
  temperatureMax    Float?
  dropPoint         Float?
  dinClassification String?
  isoClassification String?
  foodGrade         Boolean  @default(false)
  ecoResponsible    Boolean  @default(false)
  moshMoahFree      Boolean  @default(false)
  productType       String   @default("lubricant")
  active            Boolean  @default(true)
  sourceHash        String
  sourceUpdatedAt   DateTime?
  rawData           Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  references PimReference[]
  documents  PimDocument[]
  chunks     RagChunk[]

  @@index([active, productType])
  @@index([name])
  @@map("pim_products")
}

/// Sellbase level-5 commercial/logistic reference belonging to a product.
model PimReference {
  id                String   @id @default(uuid())
  sellbaseElementId Int      @unique
  productId         String
  code              String?
  label             String?
  packaging         String?
  erpStatus         String?
  active            Boolean  @default(true)
  sourceHash        String
  sourceUpdatedAt   DateTime?
  rawData           Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  product PimProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("pim_references")
}

model PimDocument {
  id              String   @id @default(uuid())
  productId       String
  sellbaseCaracId Int
  kind            String
  language        String
  fileName        String
  sourceUpdatedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product PimProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, sellbaseCaracId])
  @@index([productId, kind, language])
  @@map("pim_documents")
}

model RagIndexVersion {
  id             String         @id @default(uuid())
  version        Int            @unique @default(autoincrement())
  status         RagIndexStatus @default(building)
  embeddingModel String
  dimensions     Int
  productCount   Int            @default(0)
  chunkCount     Int            @default(0)
  metrics        Json?
  activatedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  chunks   RagChunk[]
  syncRuns RagSyncRun[]

  @@index([status])
  @@map("rag_index_versions")
}

model RagChunk {
  id          String                       @id @default(uuid())
  indexId     String
  productId   String
  content     String
  contentHash String
  metadata    Json
  embedding   Unsupported("vector(1536)")
  createdAt   DateTime                     @default(now())

  index   RagIndexVersion @relation(fields: [indexId], references: [id], onDelete: Cascade)
  product PimProduct      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([indexId, productId, contentHash])
  @@index([indexId, productId])
  @@map("rag_chunks")
}

model RagSyncRun {
  id             String         @id @default(uuid())
  status         RagSyncStatus  @default(queued)
  trigger        RagSyncTrigger
  requestedBy    String?
  indexId        String?
  startedAt      DateTime?
  finishedAt     DateTime?
  productsSeen   Int            @default(0)
  productsChanged Int           @default(0)
  productsRemoved Int           @default(0)
  referencesSeen Int            @default(0)
  chunksCreated  Int            @default(0)
  error          String?
  details        Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  index RagIndexVersion? @relation(fields: [indexId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@map("rag_sync_runs")
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String
  userId    String
  metadata  Json?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}
