{
  "expo": {
    "name": "MolyScan",
    "slug": "molyscan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "molyscan",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.molyscan.app",
      "buildNumber": "1",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "MolyScan utilise votre caméra pour photographier les produits et identifier les équivalents Molydal.",
        "NSPhotoLibraryUsageDescription": "MolyScan a besoin d'accéder à vos photos pour analyser une image depuis votre galerie.",
        "NSLocationWhenInUseUsageDescription": "MolyScan utilise votre position pour géolocaliser vos scans sur la carte.",
        "NSMicrophoneUsageDescription": "MolyScan utilise le micro pour enregistrer des notes vocales CRM."
      }
    },
    "android": {
      "package": "com.molyscan.app",
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./src/app"
        }
      ],
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow MolyScan to access your camera for barcode scanning."
        }
      ],
      "expo-sqlite",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "MolyScan utilise votre position pour géolocaliser vos scans."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "MolyScan utilise le micro pour enregistrer des notes vocales CRM."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#E87722"
        }
      ]
    ],
    "extra": {
      "router": {
        "root": "./src/app"
      },
      "eas": {
        "projectId": "7541b1aa-1bc7-461b-af82-af68fe640949"
      }
    }
  }
}
